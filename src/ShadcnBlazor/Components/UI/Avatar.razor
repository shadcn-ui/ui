@* Avatar component - Blazor port of shadcn/ui Avatar *@

<span data-slot="avatar" data-size="@Size"
      class="@CssUtils.Cn("cn-avatar group/avatar relative flex shrink-0 select-none overflow-hidden rounded-full", Class)"
      @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Src))
    {
        <img data-slot="avatar-image" src="@Src" alt="@Alt"
             class="cn-avatar-image aspect-square size-full object-cover" />
    }
    else
    {
        <span data-slot="avatar-fallback"
              class="cn-avatar-fallback flex size-full items-center justify-center text-sm group-data-[size=sm]/avatar:text-xs">
            @(Fallback ?? ChildContent)
        </span>
    }
</span>

@code {
    [Parameter] public string? Src { get; set; }
    [Parameter] public string? Alt { get; set; }
    [Parameter] public RenderFragment? Fallback { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Size { get; set; } = "default";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
