@* Sidebar component - Blazor port of shadcn/ui Sidebar *@

<aside data-slot="sidebar" class="@CssUtils.Cn("cn-sidebar", Open ? "w-[--sidebar-width]" : "w-0 overflow-hidden", Class)"
       style="--sidebar-width: @Width;"
       @attributes="AdditionalAttributes">
    @ChildContent
</aside>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Open { get; set; } = true;
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public string Width { get; set; } = "16rem";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    public async Task Toggle()
    {
        Open = !Open;
        await OpenChanged.InvokeAsync(Open);
    }
}
