  },
  "line": {
    "height": {
      "tight": 1.2
    }
  },
  "radius": {
    "sm": "4px",
    "md": "8px"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px"
