# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# generated content
.contentlayer
.content-collections
.source
.devtools

# generated registry output (rebuilt by registry:build on every deploy).
# index.json, default and new-york are NOT build outputs: index.json is a
# static contract older CLIs fetch, and default/new-york are frozen v3
# styles maintained by editing the JSON directly.
/public/r/styles/*
!/public/r/styles/index.json
!/public/r/styles/default/
!/public/r/styles/new-york/
