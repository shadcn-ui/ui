  "files": [
    {
      "path": "registry/vue-force-ui/examples/dialog/DialogCloseButton.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport {\n  Dialog,\n  DialogClose,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from \"@/ui/dialog\"\nimport { Input } from \"@/ui/input\"\nimport { Label } from \"@/ui/label\"\n</script>\n\n<template>\n  <Dialog>\n    <DialogTrigger as-child>\n      <Button variant=\"outline\"> Share </Button>\n    </DialogTrigger>\n    <DialogContent class=\"sm:max-w-md\">\n      <DialogHeader>\n        <DialogTitle>Share link</DialogTitle>\n        <DialogDescription>\n          Anyone who has this link will be able to view this.\n        </DialogDescription>\n      </DialogHeader>\n      <div class=\"flex items-center gap-2\">\n        <div class=\"grid flex-1 gap-2\">\n          <Label for=\"link\" class=\"sr-only\"> Link </Label>\n          <Input\n            id=\"link\"\n            default-value=\"https://ui.shadcn.com/docs/installation\"\n            read-only\n          />\n        </div>\n      </div>\n      <DialogFooter class=\"sm:justify-start\">\n        <DialogClose as-child>\n          <Button type=\"button\" variant=\"secondary\"> Close </Button>\n        </DialogClose>\n      </DialogFooter>\n    </DialogContent>\n  </Dialog>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-force-ui/examples/dialog/DialogDemo.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport {\n  Dialog,\n  DialogClose,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from \"@/ui/dialog\"\nimport { Input } from \"@/ui/input\"\nimport { Label } from \"@/ui/label\"\n</script>\n\n<template>\n  <Dialog>\n    <form>\n      <DialogTrigger as-child>\n        <Button variant=\"outline\"> Open Dialog </Button>\n      </DialogTrigger>\n      <DialogContent class=\"sm:max-w-[425px]\">\n        <DialogHeader>\n          <DialogTitle>Edit profile</DialogTitle>\n          <DialogDescription>\n            Make changes to your profile here. Click save when you're done.\n          </DialogDescription>\n        </DialogHeader>\n        <div class=\"grid gap-4\">\n          <div class=\"grid gap-3\">\n            <Label for=\"name-1\">Name</Label>\n            <Input id=\"name-1\" name=\"name\" default-value=\"Pedro Duarte\" />\n          </div>\n          <div class=\"grid gap-3\">\n            <Label for=\"username-1\">Username</Label>\n            <Input id=\"username-1\" name=\"username\" default-value=\"@peduarte\" />\n          </div>\n        </div>\n        <DialogFooter>\n          <DialogClose as-child>\n            <Button variant=\"outline\"> Cancel </Button>\n          </DialogClose>\n          <Button type=\"submit\"> Save changes </Button>\n        </DialogFooter>\n      </DialogContent>\n    </form>\n  </Dialog>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-force-ui/examples/dialog/DialogForm.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport {\n  Dialog,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from \"@/ui/dialog\"\nimport {\n  Field,\n  FieldDescription,\n  FieldError,\n  FieldGroup,\n  FieldLabel,\n} from \"@/ui/field\"\nimport { Input } from \"@/ui/input\"\nimport { toTypedSchema } from \"@vee-validate/zod\"\nimport { Form, Field as VeeField } from \"vee-validate\"\nimport { h } from \"vue\"\nimport { toast } from \"vue-sonner\"\nimport * as z from \"zod\"\n\nconst formSchema = toTypedSchema(\n  z.object({\n    username: z.string().min(2).max(50),\n  })\n)\n\nfunction onSubmit(values: any) {\n  toast(\"You submitted the following values:\", {\n    description: h(\n      \"pre\",\n      { class: \"mt-2 w-[320px] rounded-md bg-neutral-950 p-4\" },\n      h(\"code\", { class: \"text-white\" }, JSON.stringify(values, null, 2))\n    ),\n  })\n}\n</script>\n\n<template>\n  <Form\n    v-slot=\"{ handleSubmit }\"\n    as=\"\"\n    keep-values\n    :validation-schema=\"formSchema\"\n  >\n    <Dialog>\n      <DialogTrigger as-child>\n        <Button variant=\"outline\"> Edit Profile </Button>\n      </DialogTrigger>\n      <DialogContent class=\"sm:max-w-[425px]\">\n        <DialogHeader>\n          <DialogTitle>Edit profile</DialogTitle>\n          <DialogDescription>\n            Make changes to your profile here. Click save when you're done.\n          </DialogDescription>\n        </DialogHeader>\n\n        <form id=\"dialogForm\" @submit=\"handleSubmit($event, onSubmit)\">\n          <FieldGroup>\n            <VeeField v-slot=\"{ componentField, errors }\" name=\"username\">\n              <Field :data-invalid=\"!!errors.length\">\n                <FieldLabel for=\"username\"> Username </FieldLabel>\n                <Input\n                  id=\"username\"\n                  type=\"text\"\n                  placeholder=\"shadcn\"\n                  v-bind=\"componentField\"\n                />\n                <FieldDescription>\n                  This is your public display name.\n                </FieldDescription>\n                <FieldError v-if=\"errors.length\" :errors=\"errors\" />\n              </Field>\n            </VeeField>\n          </FieldGroup>\n        </form>\n\n        <DialogFooter>\n          <Button type=\"submit\" form=\"dialogForm\"> Save changes </Button>\n        </DialogFooter>\n      </DialogContent>\n    </Dialog>\n  </Form>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-force-ui/examples/dialog/DialogResponsive.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport {\n  Dialog,\n  DialogClose,\n  DialogContent,\n  DialogDescription,\n  DialogFooter,\n  DialogHeader,\n  DialogTitle,\n  DialogTrigger,\n} from \"@/ui/dialog\"\nimport {\n  Drawer,\n  DrawerClose,\n  DrawerContent,\n  DrawerDescription,\n  DrawerFooter,\n  DrawerHeader,\n  DrawerTitle,\n  DrawerTrigger,\n} from \"@/ui/drawer\"\nimport { Input } from \"@/ui/input\"\nimport { Label } from \"@/ui/label\"\nimport { useMediaQuery } from \"@vueuse/core\"\n\nconst isDesktop = useMediaQuery(\"(min-width: 640px)\")\n\nconst Modal = computed(() => ({\n  Root: isDesktop.value ? Dialog : Drawer,\n  Trigger: isDesktop.value ? DialogTrigger : DrawerTrigger,\n  Content: isDesktop.value ? DialogContent : DrawerContent,\n  Header: isDesktop.value ? DialogHeader : DrawerHeader,\n  Title: isDesktop.value ? DialogTitle : DrawerTitle,\n  Description: isDesktop.value ? DialogDescription : DrawerDescription,\n  Footer: isDesktop.value ? DialogFooter : DrawerFooter,\n  Close: isDesktop.value ? DialogClose : DrawerClose,\n}))\n\nconst open = ref(false)\n</script>\n\n<template>\n  <component :is=\"Modal.Root\" v-model:open=\"open\">\n    <component :is=\"Modal.Trigger\" as-child>\n      <Button variant=\"outline\"> Open Dialog </Button>\n    </component>\n    <component\n      :is=\"Modal.Content\"\n      class=\"sm:max-w-md\"\n      :class=\"[{ 'px-2 pb-8 *:px-4': !isDesktop }]\"\n    >\n      <component :is=\"Modal.Header\">\n        <component :is=\"Modal.Title\"> Share Link </component>\n        <component :is=\"Modal.Description\">\n          Anyone who has this link will be able to view this.\n        </component>\n      </component>\n\n      <div class=\"flex items-center gap-2\">\n        <div class=\"grid flex-1 gap-2\">\n          <Label for=\"link\" class=\"sr-only\"> Link </Label>\n          <Input\n            id=\"link\"\n            default-value=\"https://www.shadcn-vue.com/docs/installation\"\n            read-only\n          />\n        </div>\n      </div>\n\n      <component :is=\"Modal.Footer\" class=\"pt-4\">\n        <component :is=\"Modal.Close\" as-child>\n          <Button variant=\"outline\"> Close </Button>\n        </component>\n      </component>\n    </component>\n  </component>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}