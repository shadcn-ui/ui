{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "input-group-dropdown",
  "title": "Input Group Dropdown",
  "dependencies": [],
  "registryDependencies": [
    "dropdown-menu",
    "input-group"
  ],
  "files": [
    {
      "path": "registry/ember-force-ui/examples/input-group-dropdown.gts",
      "content": "import {\n  DropdownMenu,\n  DropdownMenuContent,\n  DropdownMenuItem,\n  DropdownMenuTrigger,\n} from '@/ui/dropdown-menu';\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupButton,\n  InputGroupInput,\n} from '@/ui/input-group';\n\nimport ChevronDown from '~icons/lucide/chevron-down';\nimport MoreHorizontal from '~icons/lucide/more-horizontal';\n\n<template>\n  <div class=\"grid w-full max-w-sm gap-4\">\n    <InputGroup>\n      <InputGroupInput placeholder=\"Enter file name\" />\n      <InputGroupAddon @align=\"inline-end\">\n        <DropdownMenu>\n          <DropdownMenuTrigger>\n            <InputGroupButton\n              @size=\"icon-xs\"\n              @variant=\"ghost\"\n              aria-label=\"More\"\n            >\n              <MoreHorizontal />\n            </InputGroupButton>\n          </DropdownMenuTrigger>\n          <DropdownMenuContent @align=\"end\">\n            <DropdownMenuItem>Settings</DropdownMenuItem>\n            <DropdownMenuItem>Copy path</DropdownMenuItem>\n            <DropdownMenuItem>Open location</DropdownMenuItem>\n          </DropdownMenuContent>\n        </DropdownMenu>\n      </InputGroupAddon>\n    </InputGroup>\n\n    <InputGroup @class=\"[--radius:1rem]\">\n      <InputGroupInput placeholder=\"Enter search query\" />\n      <InputGroupAddon @align=\"inline-end\">\n        <DropdownMenu>\n          <DropdownMenuTrigger>\n            <InputGroupButton @class=\"!pr-1.5 text-xs\" @variant=\"ghost\">\n              Search In...\n              <ChevronDown class=\"size-3\" />\n            </InputGroupButton>\n          </DropdownMenuTrigger>\n          <DropdownMenuContent @align=\"end\" @class=\"[--radius:0.95rem]\">\n            <DropdownMenuItem>Documentation</DropdownMenuItem>\n            <DropdownMenuItem>Blog Posts</DropdownMenuItem>\n            <DropdownMenuItem>Changelog</DropdownMenuItem>\n          </DropdownMenuContent>\n        </DropdownMenu>\n      </InputGroupAddon>\n    </InputGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}