{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "field-responsive-layout-demo",
  "title": "Field Responsive Layout Demo",
  "registryDependencies": [
    "button",
    "field",
    "input",
    "textarea"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/examples/field-responsive-layout-demo.svelte",
      "content": "<script lang=\"ts\">\n  import { Button } from \"$lib/registry/ui/button/index.js\"\n  import * as Field from \"$lib/registry/ui/field/index.js\"\n  import { Input } from \"$lib/registry/ui/input/index.js\"\n  import { Textarea } from \"$lib/registry/ui/textarea/index.js\"\n</script>\n\n<div class=\"w-full max-w-4xl\">\n  <form>\n    <Field.Set>\n      <Field.Legend>Profile</Field.Legend>\n      <Field.Description>Fill in your profile information.</Field.Description>\n      <Field.Separator />\n      <Field.Group>\n        <Field.Field orientation=\"responsive\">\n          <Field.Content>\n            <Field.Label for=\"name\">Name</Field.Label>\n            <Field.Description>\n              Provide your full name for identification\n            </Field.Description>\n          </Field.Content>\n          <Input id=\"name\" placeholder=\"Evil Rabbit\" required />\n        </Field.Field>\n        <Field.Separator />\n        <Field.Field orientation=\"responsive\">\n          <Field.Content>\n            <Field.Label for=\"message\">Message</Field.Label>\n            <Field.Description>\n              You can write your message here. Keep it short, preferably under\n              100 characters.\n            </Field.Description>\n          </Field.Content>\n          <Textarea\n            id=\"message\"\n            placeholder=\"Hello, world!\"\n            required\n            class=\"min-h-[100px] resize-none sm:min-w-[300px]\"\n          />\n        </Field.Field>\n        <Field.Separator />\n        <Field.Field orientation=\"responsive\">\n          <Button type=\"submit\">Submit</Button>\n          <Button type=\"button\" variant=\"outline\">Cancel</Button>\n        </Field.Field>\n      </Field.Group>\n    </Field.Set>\n  </form>\n</div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}