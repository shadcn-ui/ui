{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "field-switch",
  "title": "Field Switch",
  "registryDependencies": [
    "field",
    "switch"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/examples/field-switch.svelte",
      "content": "<script lang=\"ts\">\n  import * as Field from \"$lib/registry/ui/field/index.js\"\n  import { Switch } from \"$lib/registry/ui/switch/index.js\"\n</script>\n\n<div class=\"w-full max-w-md\">\n  <Field.Field orientation=\"horizontal\">\n    <Field.Content>\n      <Field.Label for=\"2fa\">Multi-factor authentication</Field.Label>\n      <Field.Description>\n        Enable multi-factor authentication. If you do not have a two-factor\n        device, you can use a one-time code sent to your email.\n      </Field.Description>\n    </Field.Content>\n    <Switch id=\"2fa\" />\n  </Field.Field>\n</div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}