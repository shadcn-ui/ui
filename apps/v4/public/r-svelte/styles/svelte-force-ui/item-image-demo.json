{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "item-image-demo",
  "title": "Item Image Demo",
  "registryDependencies": [
    "item"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/examples/item-image-demo.svelte",
      "content": "<script lang=\"ts\">\n  import * as Item from \"$lib/registry/ui/item/index.js\"\n\n  const music = [\n    {\n      title: \"Midnight City Lights\",\n      artist: \"Neon Dreams\",\n      album: \"Electric Nights\",\n      duration: \"3:45\",\n    },\n    {\n      title: \"Coffee Shop Conversations\",\n      artist: \"The Morning Brew\",\n      album: \"Urban Stories\",\n      duration: \"4:05\",\n    },\n    {\n      title: \"Digital Rain\",\n      artist: \"Cyber Symphony\",\n      album: \"Binary Beats\",\n      duration: \"3:30\",\n    },\n  ]\n</script>\n\n<div class=\"flex w-full max-w-md flex-col gap-6\">\n  <div class=\"flex w-full max-w-md flex-col gap-4\">\n    {#each music as song (song)}\n      <Item.Root variant=\"outline\">\n        {#snippet child({ props })}\n          <a href=\"#/\" {...props}>\n            <Item.Media variant=\"image\">\n              <img\n                src={`https://avatar.vercel.sh/${song.title}`}\n                alt={song.title}\n                width=\"32\"\n                height=\"32\"\n                class=\"size-8 rounded object-cover grayscale\"\n              />\n            </Item.Media>\n            <Item.Content>\n              <Item.Title class=\"line-clamp-1\">\n                {song.title} -\n                <span class=\"text-muted-foreground\">{song.album}</span>\n              </Item.Title>\n              <Item.Description>{song.artist}</Item.Description>\n            </Item.Content>\n            <Item.Content class=\"flex-none text-center\">\n              <Item.Description>{song.duration}</Item.Description>\n            </Item.Content>\n          </a>\n        {/snippet}\n      </Item.Root>\n    {/each}\n  </div>\n</div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}