{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "checkbox-form-single",
  "title": "Checkbox Form Single",
  "dependencies": [
    "svelte-sonner",
    "sveltekit-superforms",
    "zod"
  ],
  "registryDependencies": [
    "checkbox",
    "form"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/examples/checkbox-form-single.svelte",
      "content": "<script lang=\"ts\" module>\n  import { z } from \"zod\"\n\n  const formSchema = z.object({\n    mobile: z.boolean().default(false),\n  })\n</script>\n\n<script lang=\"ts\">\n  import { Checkbox } from \"$lib/registry/ui/checkbox/index.js\"\n  import * as Form from \"$lib/registry/ui/form/index.js\"\n  import { toast } from \"svelte-sonner\"\n  import { defaults, superForm } from \"sveltekit-superforms\"\n  import { zod4 } from \"sveltekit-superforms/adapters\"\n\n  const form = superForm(defaults(zod4(formSchema)), {\n    validators: zod4(formSchema),\n    SPA: true,\n    onUpdate: ({ form: f }) => {\n      if (f.valid) {\n        toast.success(`You submitted ${JSON.stringify(f.data, null, 2)}`)\n      } else {\n        toast.error(\"Please fix the errors in the form.\")\n      }\n    },\n  })\n\n  const { form: formData, enhance } = form\n</script>\n\n<form method=\"POST\" class=\"space-y-6\" use:enhance>\n  <Form.Field\n    {form}\n    name=\"mobile\"\n    class=\"flex flex-row items-start space-y-0 space-x-3 rounded-md border p-4\"\n  >\n    <Form.Control>\n      {#snippet children({ props })}\n        <Checkbox {...props} bind:checked={$formData.mobile} />\n        <div class=\"space-y-1 leading-none\">\n          <Form.Label>Use different settings for my mobile devices</Form.Label>\n          <Form.Description>\n            You can manage your mobile notifications in the <a\n              href=\"/examples/forms\">mobile settings</a\n            > page.\n          </Form.Description>\n        </div>\n      {/snippet}\n    </Form.Control>\n  </Form.Field>\n  <Form.Button>Submit</Form.Button>\n</form>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}