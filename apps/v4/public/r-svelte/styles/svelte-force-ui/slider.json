{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "slider",
  "dependencies": [
    "bits-ui"
  ],
  "registryDependencies": [
    "utils"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/ui/slider/index.ts",
      "content": "import Root from \"./slider.svelte\"\n\nexport {\n  Root,\n  //\n  Root as Slider,\n}\n",
      "type": "registry:ui"
    },
    {
      "path": "registry/svelte-force-ui/ui/slider/slider.svelte",
      "content": "<script lang=\"ts\">\n  import { cn, type WithoutChildrenOrChild } from \"$lib/utils.js\"\n  import { Slider as SliderPrimitive } from \"bits-ui\"\n\n  let {\n    ref = $bindable(null),\n    value = $bindable(),\n    orientation = \"horizontal\",\n    class: className,\n    ...restProps\n  }: WithoutChildrenOrChild<SliderPrimitive.RootProps> = $props()\n</script>\n\n<!--\nDiscriminated Unions + Destructing (required for bindable) do not\nget along, so we shut typescript up by casting `value` to `never`.\n-->\n<SliderPrimitive.Root\n  bind:ref\n  bind:value={value as never}\n  data-slot=\"slider\"\n  {orientation}\n  class={cn(\n    \"cn-slider relative flex w-full touch-none items-center select-none data-disabled:opacity-50 data-vertical:h-full data-vertical:w-auto data-vertical:flex-col\",\n    className\n  )}\n  {...restProps}\n>\n  {#snippet children({ thumbItems })}\n    <span\n      data-slot=\"slider-track\"\n      data-orientation={orientation}\n      class={cn(\n        \"cn-slider-track bg-muted relative grow overflow-hidden data-horizontal:w-full data-vertical:h-full\"\n      )}\n    >\n      <SliderPrimitive.Range\n        data-slot=\"slider-range\"\n        class={cn(\n          \"cn-slider-range absolute select-none data-horizontal:h-full data-vertical:w-full\"\n        )}\n      />\n    </span>\n    {#each thumbItems as thumb (thumb)}\n      <SliderPrimitive.Thumb\n        data-slot=\"slider-thumb\"\n        index={thumb.index}\n        class=\"cn-slider-thumb block shrink-0 select-none disabled:pointer-events-none disabled:opacity-50\"\n      />\n    {/each}\n  {/snippet}\n</SliderPrimitive.Root>\n",
      "type": "registry:ui"
    }
  ],
  "meta": {
    "links": {
      "docs": "https://shadcn-force-ui.vercel.app/docs/components/svelte/slider"
    }
  },
  "type": "registry:ui"
}