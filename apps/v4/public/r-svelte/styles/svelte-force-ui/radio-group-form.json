{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "radio-group-form",
  "title": "Radio Group Form",
  "dependencies": [
    "svelte-sonner",
    "sveltekit-superforms",
    "zod"
  ],
  "registryDependencies": [
    "form",
    "radio-group"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/examples/radio-group-form.svelte",
      "content": "<script lang=\"ts\" module>\n  import { z } from \"zod\"\n\n  const formSchema = z.object({\n    type: z.enum([\"all\", \"mentions\", \"none\"]),\n  })\n</script>\n\n<script lang=\"ts\">\n  import * as Form from \"$lib/registry/ui/form/index.js\"\n  import * as RadioGroup from \"$lib/registry/ui/radio-group/index.js\"\n  import { toast } from \"svelte-sonner\"\n  import { defaults, superForm } from \"sveltekit-superforms\"\n  import { zod4 } from \"sveltekit-superforms/adapters\"\n\n  const form = superForm(defaults(zod4(formSchema)), {\n    validators: zod4(formSchema),\n    SPA: true,\n    onUpdate: ({ form: f }) => {\n      if (f.valid) {\n        toast.success(`You submitted ${JSON.stringify(f.data, null, 2)}`)\n      } else {\n        toast.error(\"Please fix the errors in the form.\")\n      }\n    },\n  })\n\n  const { form: formData, enhance } = form\n</script>\n\n<form method=\"POST\" class=\"w-2/3 space-y-6\" use:enhance>\n  <Form.Fieldset {form} name=\"type\" class=\"space-y-3\">\n    <Form.Legend>Notify me about...</Form.Legend>\n    <RadioGroup.Root\n      bind:value={$formData.type}\n      class=\"flex flex-col space-y-1\"\n      name=\"type\"\n    >\n      <div class=\"flex items-center space-y-0 space-x-3\">\n        <Form.Control>\n          {#snippet children({ props })}\n            <RadioGroup.Item value=\"all\" {...props} />\n            <Form.Label class=\"font-normal\">All new messages</Form.Label>\n          {/snippet}\n        </Form.Control>\n      </div>\n      <div class=\"flex items-center space-y-0 space-x-3\">\n        <Form.Control>\n          {#snippet children({ props })}\n            <RadioGroup.Item value=\"mentions\" {...props} />\n            <Form.Label class=\"font-normal\"\n              >Direction messages and mentions</Form.Label\n            >\n          {/snippet}\n        </Form.Control>\n      </div>\n      <div class=\"flex items-center space-y-0 space-x-3\">\n        <Form.Control>\n          {#snippet children({ props })}\n            <RadioGroup.Item value=\"none\" {...props} />\n            <Form.Label class=\"font-normal\">Nothing</Form.Label>\n          {/snippet}\n        </Form.Control>\n      </div>\n    </RadioGroup.Root>\n    <Form.FieldErrors />\n  </Form.Fieldset>\n  <Form.Button>Submit</Form.Button>\n</form>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}