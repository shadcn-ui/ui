{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "item-link-demo",
  "title": "Item Link Demo",
  "registryDependencies": [
    "item"
  ],
  "files": [
    {
      "path": "registry/svelte-force-ui/examples/item-link-demo.svelte",
      "content": "<script lang=\"ts\">\n  import ChevronRightIcon from \"@lucide/svelte/icons/chevron-right\"\n  import ExternalLinkIcon from \"@lucide/svelte/icons/external-link\"\n  import * as Item from \"$lib/registry/ui/item/index.js\"\n</script>\n\n<div class=\"flex w-full max-w-md flex-col gap-4\">\n  <Item.Root>\n    {#snippet child({ props })}\n      <a href=\"#/\" {...props}>\n        <Item.Content>\n          <Item.Title>Visit our documentation</Item.Title>\n          <Item.Description>\n            Learn how to get started with our components.\n          </Item.Description>\n        </Item.Content>\n        <Item.Actions>\n          <ChevronRightIcon class=\"size-4\" />\n        </Item.Actions>\n      </a>\n    {/snippet}\n  </Item.Root>\n  <Item.Root variant=\"outline\">\n    {#snippet child({ props })}\n      <a href=\"#/\" target=\"_blank\" rel=\"noopener noreferrer\" {...props}>\n        <Item.Content>\n          <Item.Title>External resource</Item.Title>\n          <Item.Description>\n            Opens in a new tab with security attributes.\n          </Item.Description>\n        </Item.Content>\n        <Item.Actions>\n          <ExternalLinkIcon class=\"size-4\" />\n        </Item.Actions>\n      </a>\n    {/snippet}\n  </Item.Root>\n</div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}