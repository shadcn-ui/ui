      "path": "registry/vue-vega/examples/navigation-menu/NavigationMenuBasic.vue",
      "content": "<script setup lang=\"ts\">\nimport {\n  NavigationMenu,\n  NavigationMenuContent,\n  NavigationMenuItem,\n  NavigationMenuLink,\n  NavigationMenuList,\n  NavigationMenuTrigger,\n} from \"@/ui/navigation-menu\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"Basic Navigation Menu\">\n    <NavigationMenu>\n      <NavigationMenuList>\n        <NavigationMenuItem>\n          <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>\n          <NavigationMenuContent>\n            <ul\n              class=\"grid gap-3 p-6 md:w-[400px] lg:w-[500px] lg:grid-cols-[.75fr_1fr]\"\n            >\n              <li class=\"row-span-3\">\n                <NavigationMenuLink as-child>\n                  <a\n                    class=\"flex h-full w-full flex-col justify-end rounded-md bg-gradient-to-b from-muted/50 to-muted p-6 no-underline outline-none select-none focus:shadow-md\"\n                    href=\"/\"\n                  >\n                    <div class=\"mt-4 mb-2 text-lg font-medium\">shadcn/ui</div>\n                    <p class=\"text-sm leading-tight text-muted-foreground\">\n                      Beautifully designed components built with Radix UI and\n                      Tailwind CSS.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">\n                      Introduction\n                    </div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      Re-usable components built using Radix UI and Tailwind\n                      CSS.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/installation\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">\n                      Installation\n                    </div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      How to install dependencies and structure your app.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/typography\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">\n                      Typography\n                    </div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      Styles for headings, paragraphs, lists...etc\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n            </ul>\n          </NavigationMenuContent>\n        </NavigationMenuItem>\n        <NavigationMenuItem>\n          <NavigationMenuTrigger>Components</NavigationMenuTrigger>\n          <NavigationMenuContent>\n            <ul\n              class=\"grid w-[400px] gap-3 p-4 md:w-[500px] md:grid-cols-2 lg:w-[600px]\"\n            >\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/alert-dialog\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">\n                      Alert Dialog\n                    </div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      A modal dialog that interrupts the user with important\n                      content.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/hover-card\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">\n                      Hover Card\n                    </div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      For sighted users to preview content available behind a\n                      link.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/progress\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">Progress</div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      Displays an indicator showing the completion progress.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/scroll-area\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">\n                      Scroll-area\n                    </div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      Visually or semantically separates content.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/tabs\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">Tabs</div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      A set of layered sections of content—known as tab panels.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n              <li>\n                <NavigationMenuLink as-child>\n                  <a\n                    href=\"/docs/primitives/tooltip\"\n                    class=\"block space-y-1 rounded-md p-3 leading-none no-underline transition-colors outline-none select-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground\"\n                  >\n                    <div class=\"text-sm leading-none font-medium\">Tooltip</div>\n                    <p\n                      class=\"line-clamp-2 text-sm leading-snug text-muted-foreground\"\n                    >\n                      A popup that displays information related to an element.\n                    </p>\n                  </a>\n                </NavigationMenuLink>\n              </li>\n            </ul>\n          </NavigationMenuContent>\n        </NavigationMenuItem>\n        <NavigationMenuItem>\n          <NavigationMenuLink\n            href=\"/docs\"\n            class=\"group inline-flex h-10 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground focus:outline-none disabled:pointer-events-none disabled:opacity-50 data-[active]:bg-accent/50 data-[state=open]:bg-accent/50\"\n          >\n            Documentation\n          </NavigationMenuLink>\n        </NavigationMenuItem>\n      </NavigationMenuList>\n    </NavigationMenu>\n  </Example>\n</template>\n",
