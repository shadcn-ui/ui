  "files": [
    {
      "path": "registry/vue-mira/examples/spinner/SpinnerBasic.vue",
      "content": "<script setup lang=\"ts\">\nimport { Spinner } from \"@/ui/spinner\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"Basic\">\n    <div class=\"flex items-center gap-6\">\n      <Spinner />\n      <Spinner class=\"size-6\" />\n    </div>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-mira/examples/spinner/SpinnerExample.vue",
      "content": "<script setup lang=\"ts\">\nimport SpinnerBasic from \"@/examples/spinner/SpinnerBasic.vue\"\nimport SpinnerInBadges from \"@/examples/spinner/SpinnerInBadges.vue\"\nimport SpinnerInButtons from \"@/examples/spinner/SpinnerInButtons.vue\"\nimport SpinnerInEmpty from \"@/examples/spinner/SpinnerInEmpty.vue\"\nimport SpinnerInInputGroup from \"@/examples/spinner/SpinnerInInputGroup.vue\"\n\nimport { ExampleWrapper } from \"@/components/example\"\n</script>\n\n<template>\n  <ExampleWrapper>\n    <SpinnerBasic />\n    <SpinnerInButtons />\n    <SpinnerInBadges />\n    <SpinnerInInputGroup />\n    <SpinnerInEmpty />\n  </ExampleWrapper>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-mira/examples/spinner/SpinnerInBadges.vue",
      "content": "<script setup lang=\"ts\">\nimport { Badge } from \"@/ui/badge\"\nimport { Spinner } from \"@/ui/spinner\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"In Badges\" class=\"items-center justify-center\">\n    <div class=\"flex flex-wrap items-center justify-center gap-4\">\n      <Badge>\n        <Spinner data-icon=\"inline-start\" />\n        Badge\n      </Badge>\n      <Badge variant=\"secondary\">\n        <Spinner data-icon=\"inline-start\" />\n        Badge\n      </Badge>\n      <Badge variant=\"destructive\">\n        <Spinner data-icon=\"inline-start\" />\n        Badge\n      </Badge>\n      <Badge variant=\"outline\">\n        <Spinner data-icon=\"inline-start\" />\n        Badge\n      </Badge>\n    </div>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-mira/examples/spinner/SpinnerInButtons.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport { Spinner } from \"@/ui/spinner\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"In Buttons\">\n    <div class=\"flex flex-wrap items-center gap-4\">\n      <Button> <Spinner data-icon=\"inline-start\" /> Submit </Button>\n      <Button disabled> <Spinner data-icon=\"inline-start\" /> Disabled </Button>\n      <Button variant=\"outline\" disabled>\n        <Spinner data-icon=\"inline-start\" /> Outline\n      </Button>\n      <Button variant=\"outline\" size=\"icon\" disabled>\n        <Spinner data-icon=\"inline-start\" />\n        <span class=\"sr-only\">Loading...</span>\n      </Button>\n    </div>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-mira/examples/spinner/SpinnerInEmpty.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport {\n  Empty,\n  EmptyContent,\n  EmptyDescription,\n  EmptyHeader,\n  EmptyMedia,\n  EmptyTitle,\n} from \"@/ui/empty\"\nimport { Spinner } from \"@/ui/spinner\"\n\nimport { Example } from \"@/components/example\"\nimport IconPlaceholder from \"@/components/IconPlaceholder.vue\"\n</script>\n\n<template>\n  <Example title=\"In Empty State\" container-class=\"lg:col-span-full\">\n    <Empty class=\"min-h-[300px]\">\n      <EmptyHeader>\n        <EmptyMedia variant=\"icon\">\n          <Spinner />\n        </EmptyMedia>\n        <EmptyTitle>No projects yet</EmptyTitle>\n        <EmptyDescription>\n          You haven't created any projects yet. Get started by creating your\n          first project.\n        </EmptyDescription>\n      </EmptyHeader>\n      <EmptyContent>\n        <div class=\"flex gap-2\">\n          <Button :as-child=\"true\">\n            <a href=\"#\">Create project</a>\n          </Button>\n          <Button variant=\"outline\"> Import project </Button>\n        </div>\n        <Button variant=\"link\" :as-child=\"true\" class=\"text-muted-foreground\">\n          <a href=\"#\">\n            Learn more\n            <IconPlaceholder\n              lucide=\"ArrowRightIcon\"\n              tabler=\"IconArrowRight\"\n              hugeicons=\"ArrowRight02Icon\"\n              phosphor=\"ArrowRightIcon\"\n              remixicon=\"RiArrowRightLine\"\n            />\n          </a>\n        </Button>\n      </EmptyContent>\n    </Empty>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-mira/examples/spinner/SpinnerInInputGroup.vue",
      "content": "<script setup lang=\"ts\">\nimport { Field, FieldLabel } from \"@/ui/field\"\nimport { InputGroup, InputGroupAddon, InputGroupInput } from \"@/ui/input-group\"\nimport { Spinner } from \"@/ui/spinner\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"In Input Group\">\n    <Field>\n      <FieldLabel html-for=\"input-group-spinner\"> Input Group </FieldLabel>\n      <InputGroup>\n        <InputGroupInput id=\"input-group-spinner\" />\n        <InputGroupAddon>\n          <Spinner />\n        </InputGroupAddon>\n      </InputGroup>\n    </Field>\n  </Example>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}