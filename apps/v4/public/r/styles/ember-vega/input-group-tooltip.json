{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "input-group-tooltip",
  "title": "Input Group Tooltip",
  "dependencies": [],
  "registryDependencies": [
    "input-group",
    "tooltip"
  ],
  "files": [
    {
      "path": "registry/ember-vega/examples/input-group-tooltip.gts",
      "content": "import {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupButton,\n  InputGroupInput,\n} from '@/ui/input-group';\nimport {\n  Tooltip,\n  TooltipContent,\n  TooltipTrigger,\n} from '@/ui/tooltip';\n\nimport HelpCircle from '~icons/lucide/help-circle';\nimport Info from '~icons/lucide/info';\n\n<template>\n  <div class=\"grid w-full max-w-sm gap-4\">\n    <InputGroup>\n      <InputGroupInput placeholder=\"Enter password\" type=\"password\" />\n      <InputGroupAddon @align=\"inline-end\">\n        <Tooltip>\n          <TooltipTrigger>\n            <InputGroupButton\n              @size=\"icon-xs\"\n              @variant=\"ghost\"\n              aria-label=\"Info\"\n            >\n              <Info />\n            </InputGroupButton>\n          </TooltipTrigger>\n          <TooltipContent>\n            <p>Password must be at least 8 characters</p>\n          </TooltipContent>\n        </Tooltip>\n      </InputGroupAddon>\n    </InputGroup>\n\n    <InputGroup>\n      <InputGroupInput placeholder=\"Your email address\" />\n      <InputGroupAddon @align=\"inline-end\">\n        <Tooltip>\n          <TooltipTrigger>\n            <InputGroupButton\n              @size=\"icon-xs\"\n              @variant=\"ghost\"\n              aria-label=\"Help\"\n            >\n              <HelpCircle />\n            </InputGroupButton>\n          </TooltipTrigger>\n          <TooltipContent>\n            <p>We'll use this to send you notifications</p>\n          </TooltipContent>\n        </Tooltip>\n      </InputGroupAddon>\n    </InputGroup>\n\n    <InputGroup>\n      <Tooltip>\n        <TooltipTrigger>\n          <InputGroupAddon>\n            <InputGroupButton\n              @size=\"icon-xs\"\n              @variant=\"ghost\"\n              aria-label=\"Help\"\n            >\n              <HelpCircle />\n            </InputGroupButton>\n          </InputGroupAddon>\n        </TooltipTrigger>\n        <TooltipContent @side=\"left\">\n          <p>Click for help with API keys</p>\n        </TooltipContent>\n      </Tooltip>\n      <InputGroupInput placeholder=\"Enter API key\" />\n    </InputGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}