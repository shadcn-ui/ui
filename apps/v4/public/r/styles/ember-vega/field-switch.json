  ],
  "files": [
    {
      "path": "registry/ember-vega/examples/field-switch.gts",
      "content": "import {\n  Field,\n  FieldContent,\n  FieldDescription,\n  FieldLabel,\n} from '@/ui/field';\nimport { Switch } from '@/ui/switch';\n\n<template>\n  <div class=\"w-full max-w-md\">\n    <Field @orientation=\"horizontal\">\n      <FieldContent>\n        <FieldLabel @for=\"2fa\">Multi-factor authentication</FieldLabel>\n        <FieldDescription>\n          Enable multi-factor authentication. If you do not have a two-factor\n          device, you can use a one-time code sent to your email.\n        </FieldDescription>\n      </FieldContent>\n      <Switch id=\"2fa\" />\n    </Field>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}