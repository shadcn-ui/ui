      "content": "import { ButtonGroup, ButtonGroupText } from '@/ui/button-group';\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupInput,\n} from '@/ui/input-group';\nimport { Label } from '@/ui/label';\n\nimport Link2 from '~icons/lucide/link-2';\n\n<template>\n  <div class=\"grid w-full max-w-sm gap-6\">\n    <ButtonGroup>\n      <ButtonGroupText>\n        <Label for=\"url\">https://</Label>\n      </ButtonGroupText>\n      <InputGroup>\n        <InputGroupInput id=\"url\" />\n        <InputGroupAddon @align=\"inline-end\">\n          <Link2 />\n        </InputGroupAddon>\n      </InputGroup>\n      <ButtonGroupText>.com</ButtonGroupText>\n    </ButtonGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
