{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "calendar-example",
  "title": "Calendar",
  "registryDependencies": [
    "button",
    "calendar",
    "card",
    "field",
    "input-group",
    "popover",
    "example"
  ],
  "files": [
    {
      "path": "registry/ark-lyra/examples/calendar-example.tsx",
      "content": "\"use client\"\n\nimport { CalendarDate, isWeekend } from \"@internationalized/date\"\n\nimport { Example, ExampleWrapper } from \"@/registry/ark-lyra/components/example\"\nimport { Button } from \"@/registry/ark-lyra/ui/button\"\nimport {\n  Calendar,\n  CalendarDayView,\n  CalendarMonthView,\n  CalendarPresetTrigger,\n  CalendarSelectHeader,\n  CalendarYearView,\n} from \"@/registry/ark-lyra/ui/calendar\"\nimport { Card, CardContent, CardFooter } from \"@/registry/ark-lyra/ui/card\"\nimport { Field, FieldGroup, FieldLabel } from \"@/registry/ark-lyra/ui/field\"\nimport {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupInput,\n} from \"@/registry/ark-lyra/ui/input-group\"\nimport {\n  Popover,\n  PopoverContent,\n  PopoverTrigger,\n} from \"@/registry/ark-lyra/ui/popover\"\nimport { IconPlaceholder } from \"@/app/(create)/components/icon-placeholder\"\n\nexport default function CalendarExample() {\n  return (\n    <ExampleWrapper>\n      <CalendarSingle />\n      <CalendarMultiple />\n      <CalendarRange />\n      <CalendarWithViews />\n      <CalendarWithTime />\n      <CalendarCustomDays />\n      <CalendarWithPresets />\n      <CalendarInCard />\n      <CalendarInPopover />\n    </ExampleWrapper>\n  )\n}\n\nfunction CalendarSingle() {\n  return (\n    <Example title=\"Single\">\n      <Card className=\"mx-auto w-fit p-0\">\n        <CardContent className=\"p-0\">\n          <Calendar\n            defaultValue={[\n              new CalendarDate(\n                new Date().getFullYear(),\n                new Date().getMonth() + 1,\n                12\n              ),\n            ]}\n          >\n            <CalendarDayView header={<CalendarSelectHeader />} />\n          </Calendar>\n        </CardContent>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarMultiple() {\n  return (\n    <Example title=\"Multiple\">\n      <Card className=\"mx-auto w-fit p-0\">\n        <CardContent className=\"p-0\">\n          <Calendar selectionMode=\"multiple\">\n            <CalendarDayView header={<CalendarSelectHeader />} />\n          </Calendar>\n        </CardContent>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarRange() {\n  return (\n    <Example\n      title=\"Range\"\n      containerClassName=\"lg:col-span-full 2xl:col-span-full\"\n      className=\"p-12\"\n    >\n      <Card className=\"mx-auto w-fit p-0\">\n        <CardContent className=\"p-0\">\n          <Calendar\n            selectionMode=\"range\"\n            numOfMonths={2}\n            defaultValue={[\n              new CalendarDate(new Date().getFullYear(), 1, 12),\n              new CalendarDate(new Date().getFullYear(), 2, 11),\n            ]}\n          >\n            <CalendarDayView header={<CalendarSelectHeader />} />\n          </Calendar>\n        </CardContent>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarWithViews() {\n  return (\n    <Example title=\"With Views\">\n      <Card className=\"mx-auto w-fit p-0\">\n        <CardContent className=\"p-0\">\n          <Calendar\n            defaultValue={[\n              new CalendarDate(\n                new Date().getFullYear(),\n                new Date().getMonth() + 1,\n                12\n              ),\n            ]}\n          >\n            <CalendarDayView />\n            <CalendarMonthView />\n            <CalendarYearView />\n          </Calendar>\n        </CardContent>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarWithTime() {\n  return (\n    <Example title=\"With Time\">\n      <Card size=\"sm\" className=\"mx-auto w-fit\">\n        <CardContent>\n          <Calendar\n            defaultValue={[\n              new CalendarDate(\n                new Date().getFullYear(),\n                new Date().getMonth() + 1,\n                12\n              ),\n            ]}\n            className=\"p-0\"\n          >\n            <CalendarDayView header={<CalendarSelectHeader />} />\n          </Calendar>\n        </CardContent>\n        <CardFooter className=\"border-t bg-card\">\n          <FieldGroup>\n            <Field>\n              <FieldLabel htmlFor=\"time-from\">Start Time</FieldLabel>\n              <InputGroup>\n                <InputGroupInput\n                  id=\"time-from\"\n                  type=\"time\"\n                  step=\"1\"\n                  defaultValue=\"10:30:00\"\n                  className=\"appearance-none [&::-webkit-calendar-picker-indicator]:hidden [&::-webkit-calendar-picker-indicator]:appearance-none\"\n                />\n                <InputGroupAddon>\n                  <IconPlaceholder\n                    lucide=\"Clock2Icon\"\n                    tabler=\"IconClockHour2\"\n                    hugeicons=\"Clock03Icon\"\n                    phosphor=\"ClockIcon\"\n                    remixicon=\"RiTimeLine\"\n                    className=\"text-muted-foreground\"\n                  />\n                </InputGroupAddon>\n              </InputGroup>\n            </Field>\n            <Field>\n              <FieldLabel htmlFor=\"time-to\">End Time</FieldLabel>\n              <InputGroup>\n                <InputGroupInput\n                  id=\"time-to\"\n                  type=\"time\"\n                  step=\"1\"\n                  defaultValue=\"12:30:00\"\n                  className=\"appearance-none [&::-webkit-calendar-picker-indicator]:hidden [&::-webkit-calendar-picker-indicator]:appearance-none\"\n                />\n                <InputGroupAddon>\n                  <IconPlaceholder\n                    lucide=\"Clock2Icon\"\n                    tabler=\"IconClockHour2\"\n                    hugeicons=\"Clock03Icon\"\n                    phosphor=\"ClockIcon\"\n                    remixicon=\"RiTimeLine\"\n                    className=\"text-muted-foreground\"\n                  />\n                </InputGroupAddon>\n              </InputGroup>\n            </Field>\n          </FieldGroup>\n        </CardFooter>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarCustomDays() {\n  return (\n    <Example title=\"Custom Days\">\n      <Card className=\"mx-auto w-fit p-0\">\n        <CardContent className=\"p-0\">\n          <Calendar\n            selectionMode=\"range\"\n            defaultFocusedValue={\n              new CalendarDate(new Date().getFullYear(), 12, 8)\n            }\n            defaultValue={[\n              new CalendarDate(new Date().getFullYear(), 12, 8),\n              new CalendarDate(new Date().getFullYear(), 12, 18),\n            ]}\n            className=\"[--cell-size:--spacing(10)] md:[--cell-size:--spacing(12)]\"\n          >\n            <CalendarDayView\n              cell={(day) => (\n                <>\n                  {day.day}\n                  <span className=\"text-[0.6rem] text-muted-foreground\">\n                    {isWeekend(day, \"en-US\") ? \"$120\" : \"$100\"}\n                  </span>\n                </>\n              )}\n            />\n          </Calendar>\n        </CardContent>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarWithPresets() {\n  function daysFromNow(days: number) {\n    const d = new Date()\n    d.setDate(d.getDate() + days)\n    return [new CalendarDate(d.getFullYear(), d.getMonth() + 1, d.getDate())]\n  }\n\n  return (\n    <Example title=\"With Presets\">\n      <Calendar className=\"p-0 [--cell-size:--spacing(9.5)]\">\n        <Card className=\"mx-auto w-fit max-w-[300px]\" size=\"sm\">\n          <CardContent className=\"px-4\">\n            <CalendarDayView />\n          </CardContent>\n          <CardFooter className=\"flex flex-wrap gap-2 border-t\">\n            {[\n              { label: \"Today\", value: daysFromNow(0) },\n              { label: \"Tomorrow\", value: daysFromNow(1) },\n              { label: \"In 3 days\", value: daysFromNow(3) },\n              { label: \"In a week\", value: daysFromNow(7) },\n              { label: \"In 2 weeks\", value: daysFromNow(14) },\n            ].map((preset) => (\n              <CalendarPresetTrigger\n                key={preset.label}\n                value={preset.value}\n                asChild\n              >\n                <Button variant=\"outline\" size=\"sm\" className=\"flex-1\">\n                  {preset.label}\n                </Button>\n              </CalendarPresetTrigger>\n            ))}\n          </CardFooter>\n        </Card>\n      </Calendar>\n    </Example>\n  )\n}\n\nfunction CalendarInCard() {\n  return (\n    <Example title=\"In Card\">\n      <Card className=\"mx-auto w-fit p-0\">\n        <CardContent className=\"p-0\">\n          <Calendar>\n            <CalendarDayView header={<CalendarSelectHeader />} />\n          </Calendar>\n        </CardContent>\n      </Card>\n    </Example>\n  )\n}\n\nfunction CalendarInPopover() {\n  return (\n    <Example title=\"In Popover\">\n      <Popover>\n        <PopoverTrigger asChild>\n          <Button variant=\"outline\" className=\"px-2.5 font-normal\">\n            <IconPlaceholder\n              lucide=\"CalendarIcon\"\n              tabler=\"IconCalendar\"\n              hugeicons=\"Calendar03Icon\"\n              phosphor=\"CalendarIcon\"\n              remixicon=\"RiCalendarLine\"\n              data-icon=\"inline-start\"\n            />\n            Open Calendar\n          </Button>\n        </PopoverTrigger>\n        <PopoverContent className=\"w-auto p-0\">\n          <Calendar>\n            <CalendarDayView header={<CalendarSelectHeader />} />\n          </Calendar>\n        </PopoverContent>\n      </Popover>\n    </Example>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}