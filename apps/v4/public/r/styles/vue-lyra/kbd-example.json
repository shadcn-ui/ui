{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "kbd-example",
  "title": "Kbd",
  "dependencies": [
    "lucide-vue-next"
  ],
  "registryDependencies": [
    "button",
    "button-group",
    "input-group",
    "kbd",
    "tooltip"
  ],
  "files": [
    {
      "path": "registry/vue-lyra/examples/kbd/KbdDemo.vue",
      "content": "<script lang=\"ts\" setup>\nimport { Kbd, KbdGroup } from \"@/ui/kbd\"\n</script>\n\n<template>\n  <div class=\"flex flex-col items-center gap-4\">\n    <KbdGroup>\n      <Kbd>⌘</Kbd>\n      <Kbd>⇧</Kbd>\n      <Kbd>⌥</Kbd>\n      <Kbd>⌃</Kbd>\n    </KbdGroup>\n\n    <KbdGroup>\n      <Kbd>Ctrl</Kbd>\n      <span>+</span>\n      <Kbd>B</Kbd>\n    </KbdGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/kbd/KbdGroupDemo.vue",
      "content": "<script setup lang=\"ts\">\nimport { Kbd, KbdGroup } from \"@/ui/kbd\"\n</script>\n\n<template>\n  <div class=\"flex flex-col items-center gap-4\">\n    <p class=\"text-sm text-muted-foreground\">\n      Use\n      <KbdGroup>\n        <Kbd>Ctrl + B</Kbd>\n        <Kbd>Ctrl + K</Kbd>\n      </KbdGroup>\n      to open the command palette\n    </p>\n  </div>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/kbd/KbdWithButton.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport { Kbd } from \"@/ui/kbd\"\n</script>\n\n<template>\n  <div class=\"flex flex-wrap items-center gap-4\">\n    <Button variant=\"outline\" size=\"sm\" class=\"pr-2\">\n      Accept <Kbd>⏎</Kbd>\n    </Button>\n    <Button variant=\"outline\" size=\"sm\" class=\"pr-2\">\n      Cancel <Kbd>Esc</Kbd>\n    </Button>\n  </div>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/kbd/KbdWithInputGroup.vue",
      "content": "<script setup lang=\"ts\">\nimport { InputGroup, InputGroupAddon, InputGroupInput } from \"@/ui/input-group\"\nimport { Kbd } from \"@/ui/kbd\"\nimport { SearchIcon } from \"lucide-vue-next\"\n</script>\n\n<template>\n  <div class=\"flex w-full max-w-xs flex-col gap-6\">\n    <InputGroup>\n      <InputGroupInput placeholder=\"Search...\" />\n      <InputGroupAddon>\n        <SearchIcon />\n      </InputGroupAddon>\n      <InputGroupAddon align=\"inline-end\">\n        <Kbd>⌘</Kbd>\n        <Kbd>K</Kbd>\n      </InputGroupAddon>\n    </InputGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/kbd/KbdWithTooltip.vue",
      "content": "<script setup lang=\"ts\">\nimport { Button } from \"@/ui/button\"\nimport { ButtonGroup } from \"@/ui/button-group\"\nimport { Kbd, KbdGroup } from \"@/ui/kbd\"\nimport {\n  Tooltip,\n  TooltipContent,\n  TooltipProvider,\n  TooltipTrigger,\n} from \"@/ui/tooltip\"\n</script>\n\n<template>\n  <div class=\"flex flex-wrap gap-4\">\n    <ButtonGroup>\n      <TooltipProvider>\n        <Tooltip>\n          <TooltipTrigger as-child>\n            <Button size=\"sm\" variant=\"outline\"> Save </Button>\n          </TooltipTrigger>\n          <TooltipContent>\n            <div class=\"flex items-center gap-2\">Save Changes <Kbd>S</Kbd></div>\n          </TooltipContent>\n        </Tooltip>\n      </TooltipProvider>\n      <TooltipProvider>\n        <Tooltip>\n          <TooltipTrigger as-child>\n            <Button size=\"sm\" variant=\"outline\"> Print </Button>\n          </TooltipTrigger>\n          <TooltipContent>\n            <div class=\"flex items-center gap-2\">\n              Print Document\n              <KbdGroup>\n                <Kbd>Ctrl</Kbd>\n                <Kbd>P</Kbd>\n              </KbdGroup>\n            </div>\n          </TooltipContent>\n        </Tooltip>\n      </TooltipProvider>\n    </ButtonGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}