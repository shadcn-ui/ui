  "files": [
    {
      "path": "registry/vue-lyra/examples/carousel/CarouselBasic.vue",
      "content": "<script setup lang=\"ts\">\nimport { Card, CardContent } from \"@/ui/card\"\nimport {\n  Carousel,\n  CarouselContent,\n  CarouselItem,\n  CarouselNext,\n  CarouselPrevious,\n} from \"@/ui/carousel\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"Basic\">\n    <Carousel class=\"mx-auto max-w-xs sm:max-w-sm\">\n      <CarouselContent>\n        <CarouselItem v-for=\"index in 5\" :key=\"index\">\n          <div class=\"p-1\">\n            <Card>\n              <CardContent\n                class=\"flex aspect-square items-center justify-center p-6\"\n              >\n                <span class=\"text-4xl font-semibold\">{{ index }}</span>\n              </CardContent>\n            </Card>\n          </div>\n        </CarouselItem>\n      </CarouselContent>\n      <CarouselPrevious class=\"hidden sm:inline-flex\" />\n      <CarouselNext class=\"hidden sm:inline-flex\" />\n    </Carousel>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/carousel/CarouselExample.vue",
      "content": "<script setup lang=\"ts\">\nimport CarouselBasic from \"@/examples/carousel/CarouselBasic.vue\"\nimport CarouselMultiple from \"@/examples/carousel/CarouselMultiple.vue\"\nimport CarouselWithGap from \"@/examples/carousel/CarouselWithGap.vue\"\n\nimport { ExampleWrapper } from \"@/components/example\"\n</script>\n\n<template>\n  <ExampleWrapper class=\"lg:grid-cols-1\">\n    <CarouselBasic />\n    <CarouselMultiple />\n    <CarouselWithGap />\n  </ExampleWrapper>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/carousel/CarouselMultiple.vue",
      "content": "<script setup lang=\"ts\">\nimport { Card, CardContent } from \"@/ui/card\"\nimport {\n  Carousel,\n  CarouselContent,\n  CarouselItem,\n  CarouselNext,\n  CarouselPrevious,\n} from \"@/ui/carousel\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"Multiple\">\n    <Carousel\n      class=\"mx-auto max-w-xs sm:max-w-sm\"\n      :opts=\"{\n        align: 'start',\n      }\"\n    >\n      <CarouselContent>\n        <CarouselItem\n          v-for=\"index in 5\"\n          :key=\"index\"\n          class=\"sm:basis-1/2 lg:basis-1/3\"\n        >\n          <div class=\"p-1\">\n            <Card>\n              <CardContent\n                class=\"flex aspect-square items-center justify-center p-6\"\n              >\n                <span class=\"text-3xl font-semibold\">{{ index }}</span>\n              </CardContent>\n            </Card>\n          </div>\n        </CarouselItem>\n      </CarouselContent>\n      <CarouselPrevious class=\"hidden sm:inline-flex\" />\n      <CarouselNext class=\"hidden sm:inline-flex\" />\n    </Carousel>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/carousel/CarouselWithGap.vue",
      "content": "<script setup lang=\"ts\">\nimport { Card, CardContent } from \"@/ui/card\"\nimport {\n  Carousel,\n  CarouselContent,\n  CarouselItem,\n  CarouselNext,\n  CarouselPrevious,\n} from \"@/ui/carousel\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"With Gap\">\n    <Carousel class=\"mx-auto max-w-xs sm:max-w-sm\">\n      <CarouselContent class=\"-ml-1\">\n        <CarouselItem v-for=\"index in 5\" :key=\"index\" class=\"pl-1 md:basis-1/2\">\n          <div class=\"p-1\">\n            <Card>\n              <CardContent\n                class=\"flex aspect-square items-center justify-center p-6\"\n              >\n                <span class=\"text-2xl font-semibold\">{{ index }}</span>\n              </CardContent>\n            </Card>\n          </div>\n        </CarouselItem>\n      </CarouselContent>\n      <CarouselPrevious class=\"hidden sm:inline-flex\" />\n      <CarouselNext class=\"hidden sm:inline-flex\" />\n    </Carousel>\n  </Example>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}