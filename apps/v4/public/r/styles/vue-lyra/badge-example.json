      "content": "<script setup lang=\"ts\">\nimport { Badge } from \"@/ui/badge\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"asChild\">\n    <div class=\"flex flex-wrap gap-2\">\n      <Badge :as-child=\"true\">\n        <a href=\"#\">\n          Link\n          <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n            data-icon=\"inline-end\"\n          >\n            <path d=\"M7 7h10v10\" />\n            <path d=\"M7 17 17 7\" />\n          </svg>\n        </a>\n      </Badge>\n      <Badge :as-child=\"true\" variant=\"secondary\">\n        <a href=\"#\">\n          Link\n          <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n            data-icon=\"inline-end\"\n          >\n            <path d=\"M7 7h10v10\" />\n            <path d=\"M7 17 17 7\" />\n          </svg>\n        </a>\n      </Badge>\n      <Badge :as-child=\"true\" variant=\"destructive\">\n        <a href=\"#\">\n          Link\n          <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n            data-icon=\"inline-end\"\n          >\n            <path d=\"M7 7h10v10\" />\n            <path d=\"M7 17 17 7\" />\n          </svg>\n        </a>\n      </Badge>\n      <Badge :as-child=\"true\" variant=\"outline\">\n        <a href=\"#\">\n          Link\n          <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n            data-icon=\"inline-end\"\n          >\n            <path d=\"M7 7h10v10\" />\n            <path d=\"M7 17 17 7\" />\n          </svg>\n        </a>\n      </Badge>\n      <Badge :as-child=\"true\" variant=\"ghost\">\n        <a href=\"#\">\n          Link\n          <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n            data-icon=\"inline-end\"\n          >\n            <path d=\"M5 12h14\" />\n            <path d=\"m12 5 7 7-7 7\" />\n          </svg>\n        </a>\n      </Badge>\n      <Badge :as-child=\"true\" variant=\"link\">\n        <a href=\"#\">\n          Link\n          <svg\n            xmlns=\"http://www.w3.org/2000/svg\"\n            width=\"24\"\n            height=\"24\"\n            viewBox=\"0 0 24 24\"\n            fill=\"none\"\n            stroke=\"currentColor\"\n            stroke-width=\"2\"\n            stroke-linecap=\"round\"\n            stroke-linejoin=\"round\"\n            data-icon=\"inline-end\"\n          >\n            <path d=\"M5 12h14\" />\n            <path d=\"m12 5 7 7-7 7\" />\n          </svg>\n        </a>\n      </Badge>\n    </div>\n  </Example>\n</template>\n",
