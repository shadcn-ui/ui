      "path": "registry/vue-lyra/examples/badge/BadgeCustomColors.vue",
      "content": "<script setup lang=\"ts\">\nimport { Badge } from \"@/ui/badge\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"Custom Colors\" class=\"max-w-fit\">\n    <div class=\"flex flex-wrap gap-2\">\n      <Badge\n        class=\"bg-blue-600 text-blue-50 dark:bg-blue-600 dark:text-blue-50\"\n      >\n        Blue\n      </Badge>\n      <Badge\n        class=\"bg-green-600 text-green-50 dark:bg-green-600 dark:text-green-50\"\n      >\n        Green\n      </Badge>\n      <Badge class=\"bg-sky-600 text-sky-50 dark:bg-sky-600 dark:text-sky-50\">\n        Sky\n      </Badge>\n      <Badge\n        class=\"bg-purple-600 text-purple-50 dark:bg-purple-600 dark:text-purple-50\"\n      >\n        Purple\n      </Badge>\n      <Badge\n        class=\"bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300\"\n      >\n        Blue\n      </Badge>\n      <Badge\n        class=\"bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300\"\n      >\n        Green\n      </Badge>\n      <Badge class=\"bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300\">\n        Sky\n      </Badge>\n      <Badge\n        class=\"bg-purple-50 text-purple-700 dark:bg-purple-950 dark:text-purple-300\"\n      >\n        Purple\n      </Badge>\n      <Badge class=\"bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300\">\n        Red\n      </Badge>\n    </div>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/badge/BadgeExample.vue",
      "content": "<script setup lang=\"ts\">\nimport { ExampleWrapper } from \"@/components/example\"\n\nimport BadgeAsLink from \"./BadgeAsLink.vue\"\nimport BadgeCustomColors from \"./BadgeCustomColors.vue\"\nimport BadgeLongText from \"./BadgeLongText.vue\"\nimport BadgeVariants from \"./BadgeVariants.vue\"\nimport BadgeWithIconLeft from \"./BadgeWithIconLeft.vue\"\nimport BadgeWithIconRight from \"./BadgeWithIconRight.vue\"\nimport BadgeWithSpinner from \"./BadgeWithSpinner.vue\"\n</script>\n\n<template>\n  <ExampleWrapper class=\"lg:grid-cols-1\">\n    <BadgeVariants />\n    <BadgeWithIconLeft />\n    <BadgeWithIconRight />\n    <BadgeWithSpinner />\n    <BadgeAsLink />\n    <BadgeLongText />\n    <BadgeCustomColors />\n  </ExampleWrapper>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-lyra/examples/badge/BadgeLongText.vue",
      "content": "<script setup lang=\"ts\">\nimport { Badge } from \"@/ui/badge\"\n\nimport { Example } from \"@/components/example\"\n</script>\n\n<template>\n  <Example title=\"Long Text\">\n    <div class=\"flex flex-wrap gap-2\">\n      <Badge variant=\"secondary\">\n        A badge with a lot of text to see how it wraps\n      </Badge>\n    </div>\n  </Example>\n</template>\n",
      "type": "registry:example"
    },
    {
