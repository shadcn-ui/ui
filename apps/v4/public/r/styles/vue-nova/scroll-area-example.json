{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "scroll-area-example",
  "title": "Scroll Area",
  "dependencies": [],
  "registryDependencies": [
    "example",
    "scroll-area",
    "separator"
  ],
  "files": [
    {
      "path": "registry/vue-nova/examples/scroll-area/ScrollAreaExample.vue",
      "content": "<script setup lang=\"ts\">\nimport ScrollAreaHorizontal from \"@/examples/scroll-area/ScrollAreaHorizontal.vue\"\nimport ScrollAreaVertical from \"@/examples/scroll-area/ScrollAreaVertical.vue\"\n\nimport { Example, ExampleWrapper } from \"@/components/example\"\n</script>\n\n<template>\n  <ExampleWrapper>\n    <Example title=\"Vertical\">\n      <ScrollAreaVertical />\n    </Example>\n    <Example title=\"Horizontal\">\n      <ScrollAreaHorizontal />\n    </Example>\n  </ExampleWrapper>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-nova/examples/scroll-area/ScrollAreaHorizontal.vue",
      "content": "<script setup lang=\"ts\">\nimport { ScrollArea, ScrollBar } from \"@/ui/scroll-area\"\n\nconst works = [\n  {\n    artist: \"Ornella Binni\",\n    art: \"https://images.unsplash.com/photo-1465869185982-5a1a7522cbcb?auto=format&fit=crop&w=300&q=80\",\n  },\n  {\n    artist: \"Tom Byrom\",\n    art: \"https://images.unsplash.com/photo-1548516173-3cabfa4607e9?auto=format&fit=crop&w=300&q=80\",\n  },\n  {\n    artist: \"Vladimir Malyav\",\n    art: \"https://images.unsplash.com/photo-1494337480532-3725c85fd2ab?auto=format&fit=crop&w=300&q=80\",\n  },\n]\n</script>\n\n<template>\n  <ScrollArea class=\"mx-auto w-full max-w-96 rounded-md border p-4\">\n    <div class=\"flex gap-4\">\n      <figure v-for=\"artwork in works\" :key=\"artwork.artist\" class=\"shrink-0\">\n        <div class=\"overflow-hidden rounded-md\">\n          <img\n            :src=\"artwork.art\"\n            :alt=\"`Photo by ${artwork.artist}`\"\n            class=\"aspect-[3/4] h-fit w-fit object-cover\"\n            width=\"300\"\n            height=\"400\"\n          />\n        </div>\n        <figcaption class=\"pt-2 text-xs text-muted-foreground\">\n          Photo by\n          <span class=\"font-semibold text-foreground\">\n            {{ artwork.artist }}\n          </span>\n        </figcaption>\n      </figure>\n    </div>\n    <ScrollBar orientation=\"horizontal\" />\n  </ScrollArea>\n</template>\n",
      "type": "registry:example"
    },
    {
      "path": "registry/vue-nova/examples/scroll-area/ScrollAreaVertical.vue",
      "content": "<script setup lang=\"ts\">\nimport { ScrollArea } from \"@/ui/scroll-area\"\nimport { Separator } from \"@/ui/separator\"\n\nconst tags = Array.from({ length: 50 }).map(\n  (_, i, a) => `v1.2.0-beta.${a.length - i}`\n)\n</script>\n\n<template>\n  <ScrollArea class=\"mx-auto h-72 w-48 rounded-md border\">\n    <div class=\"p-4\">\n      <h4 class=\"mb-4 text-sm leading-none font-medium\">Tags</h4>\n      <template v-for=\"tag in tags\" :key=\"tag\">\n        <div class=\"text-sm\">\n          {{ tag }}\n        </div>\n        <Separator class=\"my-2\" />\n      </template>\n    </div>\n  </ScrollArea>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}