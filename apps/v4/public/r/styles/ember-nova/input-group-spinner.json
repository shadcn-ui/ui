{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "input-group-spinner",
  "title": "Input Group Spinner",
  "dependencies": [],
  "registryDependencies": [
    "input-group",
    "spinner"
  ],
  "files": [
    {
      "path": "registry/ember-nova/examples/input-group-spinner.gts",
      "content": "import {\n  InputGroup,\n  InputGroupAddon,\n  InputGroupInput,\n  InputGroupText,\n} from '@/ui/input-group';\nimport { Spinner } from '@/ui/spinner';\n\nimport LoaderIcon from '~icons/lucide/loader';\n\n<template>\n  <div class=\"grid w-full max-w-sm gap-4\">\n    <InputGroup data-disabled>\n      <InputGroupInput disabled placeholder=\"Searching...\" />\n      <InputGroupAddon @align=\"inline-end\">\n        <Spinner />\n      </InputGroupAddon>\n    </InputGroup>\n\n    <InputGroup data-disabled>\n      <InputGroupInput disabled placeholder=\"Processing...\" />\n      <InputGroupAddon>\n        <Spinner />\n      </InputGroupAddon>\n    </InputGroup>\n\n    <InputGroup data-disabled>\n      <InputGroupInput disabled placeholder=\"Saving changes...\" />\n      <InputGroupAddon @align=\"inline-end\">\n        <InputGroupText>Saving...</InputGroupText>\n        <Spinner />\n      </InputGroupAddon>\n    </InputGroup>\n\n    <InputGroup data-disabled>\n      <InputGroupInput disabled placeholder=\"Refreshing data...\" />\n      <InputGroupAddon>\n        <LoaderIcon class=\"animate-spin\" />\n      </InputGroupAddon>\n      <InputGroupAddon @align=\"inline-end\">\n        <InputGroupText @class=\"text-muted-foreground\">\n          Please wait...\n        </InputGroupText>\n      </InputGroupAddon>\n    </InputGroup>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}