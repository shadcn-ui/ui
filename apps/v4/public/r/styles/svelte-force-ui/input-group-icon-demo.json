  "files": [
    {
      "path": "registry/svelte-force-ui/examples/input-group-icon-demo.svelte",
      "content": "<script lang=\"ts\">\n  import CheckIcon from \"~icons/ms/check\"\n  import CreditCardIcon from \"~icons/ms/credit_card\"\n  import InfoIcon from \"~icons/ms/info\"\n  import MailIcon from \"~icons/ms/mail\"\n  import SearchIcon from \"~icons/ms/search\"\n  import StarIcon from \"~icons/ms/star\"\n  import * as InputGroup from \"$lib/registry/ui/input-group/index.js\"\n</script>\n\n<div class=\"grid w-full max-w-sm gap-6\">\n  <InputGroup.Root>\n    <InputGroup.Input placeholder=\"Search...\" />\n    <InputGroup.Addon>\n      <SearchIcon />\n    </InputGroup.Addon>\n  </InputGroup.Root>\n  <InputGroup.Root>\n    <InputGroup.Input type=\"email\" placeholder=\"Enter your email\" />\n    <InputGroup.Addon>\n      <MailIcon />\n    </InputGroup.Addon>\n  </InputGroup.Root>\n  <InputGroup.Root>\n    <InputGroup.Input placeholder=\"Card number\" />\n    <InputGroup.Addon>\n      <CreditCardIcon />\n    </InputGroup.Addon>\n    <InputGroup.Addon align=\"inline-end\">\n      <CheckIcon />\n    </InputGroup.Addon>\n  </InputGroup.Root>\n  <InputGroup.Root>\n    <InputGroup.Input placeholder=\"Card number\" />\n    <InputGroup.Addon align=\"inline-end\">\n      <StarIcon />\n      <InfoIcon />\n    </InputGroup.Addon>\n  </InputGroup.Root>\n</div>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
