{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "marker-example",
  "title": "Marker",
  "registryDependencies": [
    "marker",
    "button",
    "collapsible",
    "drawer",
    "spinner",
    "example"
  ],
  "files": [
    {
      "path": "registry/radix-nova/examples/marker-example.tsx",
      "content": "\"use client\"\n\nimport { toast } from \"sonner\"\n\nimport {\n  Example,\n  ExampleWrapper,\n} from \"@/registry/radix-nova/components/example\"\nimport {\n  Accordion,\n  AccordionContent,\n  AccordionItem,\n  AccordionTrigger,\n} from \"@/registry/radix-nova/ui/accordion\"\nimport { Button } from \"@/registry/radix-nova/ui/button\"\nimport {\n  Drawer,\n  DrawerClose,\n  DrawerContent,\n  DrawerDescription,\n  DrawerFooter,\n  DrawerHeader,\n  DrawerTitle,\n  DrawerTrigger,\n} from \"@/registry/radix-nova/ui/drawer\"\nimport {\n  Marker,\n  MarkerContent,\n  MarkerIcon,\n} from \"@/registry/radix-nova/ui/marker\"\nimport { Spinner } from \"@/registry/radix-nova/ui/spinner\"\nimport { IconPlaceholder } from \"@/app/(create)/components/icon-placeholder\"\n\nexport default function MarkerExamples() {\n  return (\n    <ExampleWrapper>\n      <MarkerExample />\n      <MarkerBorder />\n      <MarkerSeparator />\n      <MarkerAccordion />\n      <MarkerDrawer />\n    </ExampleWrapper>\n  )\n}\n\nfunction MarkerExample() {\n  return (\n    <Example title=\"Markers\" className=\"gap-8\">\n      <Marker>\n        <MarkerContent>A default marker</MarkerContent>\n      </Marker>\n      <Marker>\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"FileTextIcon\"\n            tabler=\"IconFileDescription\"\n            hugeicons=\"File01Icon\"\n            phosphor=\"FileTextIcon\"\n            remixicon=\"RiFileTextLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Marker with icon</MarkerContent>\n      </Marker>\n      <Marker role=\"status\">\n        <MarkerIcon>\n          <Spinner />\n        </MarkerIcon>\n        <MarkerContent>Marker with a spinner</MarkerContent>\n      </Marker>\n      <Marker role=\"status\">\n        <MarkerIcon>\n          <Spinner />\n        </MarkerIcon>\n        <MarkerContent className=\"shimmer\">\n          Marker with shimmer effect\n        </MarkerContent>\n      </Marker>\n      <Marker role=\"status\">\n        <MarkerContent className=\"shimmer\">Thinking...</MarkerContent>\n      </Marker>\n      <Marker asChild>\n        <a href=\"#\">\n          <MarkerIcon>\n            <IconPlaceholder\n              lucide=\"GitBranchIcon\"\n              tabler=\"IconGitBranch\"\n              hugeicons=\"GitBranchIcon\"\n              phosphor=\"GitBranchIcon\"\n              remixicon=\"RiGitBranchLine\"\n            />\n          </MarkerIcon>\n          <MarkerContent>Marker as a link</MarkerContent>\n        </a>\n      </Marker>\n      <Marker asChild>\n        <button\n          onClick={() => toast(\"You clicked the button\")}\n          className=\"transition-colors hover:text-foreground\"\n        >\n          <MarkerIcon>\n            <IconPlaceholder\n              lucide=\"ClockIcon\"\n              tabler=\"IconClock\"\n              hugeicons=\"Clock01Icon\"\n              phosphor=\"ClockIcon\"\n              remixicon=\"RiTimeLine\"\n            />\n          </MarkerIcon>\n          <MarkerContent className=\"flex-1\">\n            <div>Marker as a button</div>\n          </MarkerContent>\n          <MarkerIcon>\n            <IconPlaceholder\n              lucide=\"ChevronRightIcon\"\n              tabler=\"IconChevronRight\"\n              hugeicons=\"ArrowRight01Icon\"\n              phosphor=\"CaretRightIcon\"\n              remixicon=\"RiArrowRightSLine\"\n            />\n          </MarkerIcon>\n        </button>\n      </Marker>\n      <Marker>\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"CircleUserIcon\"\n            tabler=\"IconUserCircle\"\n            hugeicons=\"UserCircleIcon\"\n            phosphor=\"UserCircleIcon\"\n            remixicon=\"RiUserSmileLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Rhea joined the chat</MarkerContent>\n      </Marker>\n      <Marker className=\"justify-center\">\n        <MarkerContent>\n          <strong className=\"font-medium\">Olivia Rose</strong> left the chat\n        </MarkerContent>\n      </Marker>\n      <Marker className=\"flex-col\">\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"FileTextIcon\"\n            tabler=\"IconFileDescription\"\n            hugeicons=\"File01Icon\"\n            phosphor=\"FileTextIcon\"\n            remixicon=\"RiFileTextLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Marker with icon at the top</MarkerContent>\n      </Marker>\n    </Example>\n  )\n}\n\nfunction MarkerBorder() {\n  return (\n    <Example title=\"Border\" className=\"gap-3\">\n      <Marker variant=\"border\">\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"GitBranchIcon\"\n            tabler=\"IconGitBranch\"\n            hugeicons=\"GitBranchIcon\"\n            phosphor=\"GitBranchIcon\"\n            remixicon=\"RiGitBranchLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Switched to release-candidate</MarkerContent>\n      </Marker>\n      <Marker variant=\"border\">\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"SearchIcon\"\n            tabler=\"IconSearch\"\n            hugeicons=\"Search01Icon\"\n            phosphor=\"MagnifyingGlassIcon\"\n            remixicon=\"RiSearchLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Reviewed 8 related files</MarkerContent>\n      </Marker>\n      <Marker variant=\"border\">\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"FileTextIcon\"\n            tabler=\"IconFileDescription\"\n            hugeicons=\"File01Icon\"\n            phosphor=\"FileTextIcon\"\n            remixicon=\"RiFileTextLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Opened implementation notes</MarkerContent>\n      </Marker>\n    </Example>\n  )\n}\n\nfunction MarkerSeparator() {\n  return (\n    <Example title=\"Separator\" className=\"gap-8\">\n      <Marker variant=\"separator\">\n        <MarkerContent>Worked for 42s</MarkerContent>\n      </Marker>\n      <Marker variant=\"separator\" role=\"status\">\n        <MarkerIcon>\n          <Spinner />\n        </MarkerIcon>\n        <MarkerContent>Compacting conversation</MarkerContent>\n      </Marker>\n      <Marker variant=\"separator\" role=\"status\">\n        <MarkerContent className=\"shimmer\">Reading 4 files</MarkerContent>\n      </Marker>\n      <Marker variant=\"separator\">\n        <MarkerIcon>\n          <IconPlaceholder\n            lucide=\"CheckIcon\"\n            tabler=\"IconCheck\"\n            hugeicons=\"Tick02Icon\"\n            phosphor=\"CheckIcon\"\n            remixicon=\"RiCheckLine\"\n          />\n        </MarkerIcon>\n        <MarkerContent>Conversation compacted</MarkerContent>\n      </Marker>\n      <Marker variant=\"separator\">\n        <MarkerContent>\n          With a <a href=\"#\">link to learn more</a>\n        </MarkerContent>\n      </Marker>\n      <Marker variant=\"separator\">\n        <MarkerContent>\n          <Button variant=\"outline\">\n            <IconPlaceholder\n              lucide=\"GitBranchIcon\"\n              tabler=\"IconGitBranch\"\n              hugeicons=\"GitBranchIcon\"\n              phosphor=\"GitBranchIcon\"\n              remixicon=\"RiGitBranchLine\"\n            />\n            Button\n          </Button>\n        </MarkerContent>\n      </Marker>\n    </Example>\n  )\n}\n\nfunction MarkerAccordion() {\n  return (\n    <Example title=\"Accordion\" containerClassName=\"min-h-72\">\n      <Accordion type=\"single\" collapsible>\n        <AccordionItem value=\"1\">\n          <AccordionTrigger>\n            <Marker>\n              <MarkerIcon>\n                <IconPlaceholder\n                  lucide=\"ClockIcon\"\n                  tabler=\"IconClock\"\n                  hugeicons=\"Clock01Icon\"\n                  phosphor=\"ClockIcon\"\n                  remixicon=\"RiTimeLine\"\n                />\n              </MarkerIcon>\n              <MarkerContent>Worked for 42s</MarkerContent>\n            </Marker>\n          </AccordionTrigger>\n          <AccordionContent>\n            <p className=\"text-sm text-muted-foreground\">\n              The user asked for a list of all the files in the current\n              directory. The assistant responded with a list of all the files in\n              the current directory.\n            </p>\n          </AccordionContent>\n        </AccordionItem>\n      </Accordion>\n    </Example>\n  )\n}\n\nfunction MarkerDrawer() {\n  return (\n    <Example title=\"Drawer\">\n      <Drawer direction=\"right\">\n        <Marker variant=\"separator\">\n          <DrawerTrigger asChild>\n            <Button variant=\"outline\">\n              <IconPlaceholder\n                lucide=\"SearchIcon\"\n                tabler=\"IconSearch\"\n                hugeicons=\"SearchIcon\"\n                phosphor=\"MagnifyingGlassIcon\"\n                remixicon=\"RiSearchLine\"\n                data-icon=\"inline-start\"\n              />\n              Explored 4 files\n            </Button>\n          </DrawerTrigger>\n        </Marker>\n        <DrawerContent>\n          <DrawerHeader>\n            <DrawerTitle>File Activity</DrawerTitle>\n            <DrawerDescription>\n              Files read while preparing the response.\n            </DrawerDescription>\n          </DrawerHeader>\n          <div className=\"grid gap-3 px-4 text-sm\">\n            <div className=\"flex items-center justify-between gap-4 rounded-md border px-3 py-2\">\n              <span className=\"truncate\">app/chat/page.tsx</span>\n              <span className=\"text-muted-foreground\">read</span>\n            </div>\n            <div className=\"flex items-center justify-between gap-4 rounded-md border px-3 py-2\">\n              <span className=\"truncate\">components/message.tsx</span>\n              <span className=\"text-muted-foreground\">read</span>\n            </div>\n            <div className=\"flex items-center justify-between gap-4 rounded-md border px-3 py-2\">\n              <span className=\"truncate\">lib/ai.ts</span>\n              <span className=\"text-muted-foreground\">read</span>\n            </div>\n          </div>\n          <DrawerFooter>\n            <DrawerClose asChild>\n              <Button variant=\"outline\">Close</Button>\n            </DrawerClose>\n          </DrawerFooter>\n        </DrawerContent>\n      </Drawer>\n    </Example>\n  )\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}