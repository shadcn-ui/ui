      "path": "registry/vue-maia/examples/drawer/DrawerExample.vue",
      "content": "<script setup lang=\"ts\">\nimport DrawerScrollableContent from \"@/examples/drawer/DrawerScrollableContent.vue\"\nimport DrawerWithSides from \"@/examples/drawer/DrawerWithSides.vue\"\n\nimport { ExampleWrapper } from \"@/components/example\"\n</script>\n\n<template>\n  <ExampleWrapper>\n    <DrawerScrollableContent />\n    <DrawerWithSides />\n  </ExampleWrapper>\n</template>\n",
