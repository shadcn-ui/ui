  "files": [
    {
      "path": "registry/ember-mira/examples/item-icon.gts",
      "content": "import { Button } from '@/ui/button';\nimport {\n  Item,\n  ItemActions,\n  ItemContent,\n  ItemDescription,\n  ItemMedia,\n  ItemTitle,\n} from '@/ui/item';\n\nimport ShieldAlertIcon from '~icons/lucide/shield-alert';\n\n<template>\n  <div class=\"flex w-full max-w-lg flex-col gap-6\">\n    <Item @variant=\"outline\">\n      <ItemMedia @variant=\"icon\">\n        <ShieldAlertIcon />\n      </ItemMedia>\n      <ItemContent>\n        <ItemTitle>Security Alert</ItemTitle>\n        <ItemDescription>\n          New login detected from unknown device.\n        </ItemDescription>\n      </ItemContent>\n      <ItemActions>\n        <Button @size=\"sm\" @variant=\"outline\">\n          Review\n        </Button>\n      </ItemActions>\n    </Item>\n  </div>\n</template>\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}