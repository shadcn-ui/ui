{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@force-ui/variants/*": ["../../../packages/force-ui-variants/src/*"]
    }
  },
  "include": ["src"]
}
